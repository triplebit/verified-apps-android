# Google Play package for the dedicated Play build. This is intentionally NOT
# org.privacyguides.verifiedapps: the canonical GitHub build keeps that ID and
# its own reproducible signing key, while the Play build lives under a distinct
# package so the two can never collide or be confused.
package_name("org.privacyguides.verifiedapps.play")

# Service-account JSON for the Play Developer API. In CI this is written to a
# temp file from the PLAY_SERVICE_ACCOUNT_JSON secret and its path exported as
# PLAY_JSON_KEY_FILE. Locally, point PLAY_JSON_KEY_FILE at your own key.
json_key_file(ENV.fetch("PLAY_JSON_KEY_FILE", ""))
