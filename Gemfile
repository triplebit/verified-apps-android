source "https://rubygems.org"

# fastlane drives the Google Play upload (`supply` / upload_to_play_store) and
# manages the store listing under fastlane/metadata. CI installs this via
# ruby/setup-ruby with bundler-cache; Gemfile.lock pins the full tree. To
# update: `bundle lock --update` on Ruby 3.3 and review the lockfile diff.
gem "fastlane", "~> 2.236"
